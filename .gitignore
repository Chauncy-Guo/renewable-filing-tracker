# 例外: scripts/download_new.js 是正式入口, 需要入仓
!scripts/download_new.js

# 输出目录 (运行时生成)
output/_tmp_*.json
output/_manifest*.json

# =====================================================
# output/ 下所有数据产物 + 文档不入仓, 仅保留目录占位
# =====================================================
# 缓存 / 中间 JSON
output/api_records_target.json

# 数据产物
output/PDFs/*
output/Excel/*
output/汇总/*

# 文档 (用户要求 output 下的文档不入仓)
output/docs/*
output/docs/**

# 保留每个子目录的 .gitkeep 占位 (让 git 跟踪目录结构)
!output/PDFs/.gitkeep
!output/Excel/.gitkeep
!output/汇总/.gitkeep
!output/docs/.gitkeep

# 编辑器
.idea/
.vscode/
*.swp
.DS_Store

# 虚拟环境
venv/
env/
.venv/
