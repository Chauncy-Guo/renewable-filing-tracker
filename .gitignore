__pycache__/
*.py[cod]
*$py.class

# Node
node_modules/
npm-debug.log*

# 临时 / 调试产物
_*.py
_*.mjs
_*.cjs
_*.js
_*.txt
_*.html
_*.png
~$*
__new_*
all_records.json
